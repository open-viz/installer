<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Alertmanager Notification</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 14px;
      line-height: 1.4;
      color: #222;
    }
    .status-firing {
      color: #c62828;
      font-weight: bold;
    }
    .status-resolved {
      color: #2e7d32;
      font-weight: bold;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
      vertical-align: top;
      white-space: normal;
      word-wrap: break-word;
      font-size: 14px;
      line-height: 1.2;
    }
    th {
      background-color: #f0f0f0;
      font-weight: bold;
    }
    pre {
      margin: 0;
      padding: 8px;
      text-align: left;
      white-space: pre-wrap;
      overflow-x: auto;
      font-size: 13px;
      line-height: 1.3;
      background-color: #f8f8f8;
      border: 1px solid #e0e0e0;
      border-radius: 4px;
    }
    .main-table {
      table-layout: fixed;
      width: 100%;
    }
    .main-table th:nth-child(1), .main-table td:nth-child(1) { width: 10%; }
    .main-table th:nth-child(2), .main-table td:nth-child(2) { width: 18%; }
    .main-table th:nth-child(3), .main-table td:nth-child(3) { width: 26%; }
    .main-table th:nth-child(4), .main-table td:nth-child(4) { width: 46%; }
  </style>
</head>
<body>
  <table class="main-table">
    <tr>
      <th>Status</th>
      <th>Started At</th>
      <th>Labels</th>
      <th>Content</th>
    </tr>
    {{- range .Alerts }}
    <tr>
      <td>
        {{- if eq .Status "firing" -}}
        <span class="status-firing">FIRING</span>
        {{- else if eq .Status "resolved" -}}
        <span class="status-resolved">RESOLVED</span>
        {{- else -}}
        {{ .Status | toUpper }}
        {{- end -}}
      </td>
      <td>{{ .StartsAt }}</td>
      <td>
        {{- range .Labels.SortedPairs }}
        <div><strong>{{ .Name }}</strong>: {{ .Value }}</div>
        {{- end }}
      </td>
      <td>
        {{- if .Annotations.summary }}
        <div><strong>Summary</strong></div>
        <pre>{{ .Annotations.summary }}</pre>
        {{- end }}
        {{- if .Annotations.description }}
        <div style="margin-top:8px;"><strong>Description</strong></div>
        <pre>{{ .Annotations.description }}</pre>
        {{- end }}
        {{- if .Annotations.runbook_url }}
        <div style="margin-top:8px;"><strong>Runbook</strong></div>
        <div><a href="{{ .Annotations.runbook_url }}">{{ .Annotations.runbook_url }}</a></div>
        {{- end }}
      </td>
    </tr>
    {{- end }}
  </table>
</body>
</html>
